{
  "name": "@optimist-video/mistplayer-core",
  "version": "1.1.4",
  "description": "Adaptive streaming media player with automatic protocol selection, multi-player support, and fully customizable.",
  "type": "module",
  "main": "dist/player.iife.js",
  "module": "dist/index.js",
  "unpkg": "dist/player.iife.js",
  "jsdelivr": "dist/player.iife.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/player.iife.js"
    },
    "./iife": "./dist/player.iife.js",
    "./skins/*": "./dist/skins/*"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "bash build.sh",
    "dev": "npx esbuild src/iife.js --bundle --format=iife --outfile=dist/player.iife.js --watch"
  },
  "license": "Unlicense",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DDVTECH/mistserver.git",
    "directory": "embed"
  },
  "devDependencies": {
    "esbuild": "^0.27.3"
  }
}
